# Shared secrets — used by multiple services.
# Copy to dev.env before starting the container.

# Authentication and encryption (shared)
TRT_JWT_SECRET=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef
TRT_MFA_SECRET=abcdef0123456789abcdef0123456789abcdef0123456789abcdef0123456789
TRT_CONFIG_ENCRYPTION_KEY=fedcba9876543210fedcba9876543210fedcba9876543210fedcba9876543210
TRT_BACKUP_ENCRYPTION_KEY=1111111111111111111111111111111111111111111111111111111111111111
TRT_DSAR_ENCRYPTION_KEY=2222222222222222222222222222222222222222222222222222222222222222
TRT_EXPORT_ENCRYPTION_KEY=3333333333333333333333333333333333333333333333333333333333333333
TRT_ADMIN_TOKEN=dev_admin_token_32chars_abcdefgh

# NATS
TRT_NATS_URL=nats://127.0.0.1:4222

# Redis
TRT_REDIS_URL=redis://127.0.0.1:6379

# Authenticator URL (used by API and notifier services)
TRT_AUTHENTICATOR_URL=http://127.0.0.1:50002

# Storage service URL (used by API service)
TRT_STORAGE_SERVICE_URL=http://127.0.0.1:8082

# Chunk storage path
TRT_STORAGE_BASE_PATH=/data/hashstore/chunks

# SMTP port for Mailpit (notifier defaults to 587, override to 1025)
TRT_SMTP_PORT=1025

# Audit port override (default 8083 conflicts with notifier)
TRT_HASHSTORE_AUDIT_PORT=8084

# Per-service database URLs (each service reads its own TRT_*_DATABASE_URL)
TRT_AUTH_DATABASE_URL=postgres://trt_auth_app:dev_password@127.0.0.1:5432/trauth?sslmode=disable
TRT_HASHSTORE_API_DATABASE_URL=postgres://trt_hashstore_app:dev_password@127.0.0.1:5432/hashstore_api?sslmode=disable
TRT_HASHSTORE_STORAGE_DATABASE_URL=postgres://trt_hashstore_storage_app:dev_password@127.0.0.1:5432/hashstore_storage?sslmode=disable
TRT_HASHSTORE_CAPACITY_DATABASE_URL=postgres://trt_hashstore_capacity_app:dev_password@127.0.0.1:5432/hashstore_capacity?sslmode=disable
TRT_HASHSTORE_NOTIFIER_DATABASE_URL=postgres://trt_hashstore_notification_app:dev_password@127.0.0.1:5432/hashstore_notification?sslmode=disable
TRT_HASHSTORE_AUDIT_DATABASE_URL=postgres://trt_hashstore_audit_app:dev_password@127.0.0.1:5432/hashstore_audit?sslmode=disable
